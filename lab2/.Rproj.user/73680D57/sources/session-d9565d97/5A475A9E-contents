#1.5
```{r}

#Grouping bmp cost and dam height by state name so I can join as a one to one
StateCost <- bmps %>% group_by(StateAbbreviation) %>% summarise(avgcost = mean(Cost, na.rm=T))
DamHeight <- dams %>% group_by(STATE) %>% summarise(avgheight = mean(HEIGHT, na.rm=T))
StateCost
DamHeight

#joining
dams.statecost <- left_join(DamHeight, StateCost, by= c("STATE"="StateAbbreviation"))
dams.statecost

#plotting to see any correlation between avg bmp cost and dam height within states
dams.statecost %>%
  ggplot(., aes(x=avgheight, y=avgcost, color=STATE)) +
  geom_point(size=3) + theme_minimal() +
  labs(title = "Dam Height and Sediment Reduction Cost", subtitle = "In Maryland, Pennsylvania, and Virgina", x="Average dam height", y="Average managment cost")

```

