#2.4
```{r}
glimpse(dams)
glimpse(streams)
st_crs(dams)==st_crs(streams)

# making distance matrix
distances <- st_distance(dams, streams)
dim(distances)
distances[1:3,1:3]

# finding the smallest distance in each row
dams$dist <- apply(distances, 1, which.min)
dams$dist
dams %>% select(DAM_NAME, dist) %>% glimpse()

#finding the stream thats the smallest distance to each dam
close.stream <- dams$dist %>% streams[.,] %>% select(GNIS_Name)
close.stream
closest <- tibble(dam = dams$DAM_NAME, closest.stream = close.stream)
closest


```

