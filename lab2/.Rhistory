library(tidyverse)
library(sf)
library(tmap)
streams <- sf::read_sf("./CBW/Streams_Opened_by_Dam_Removal_2012_2017.shp") %>% sf::st_make_valid()
dams <- sf::read_sf("./CBW/Dam_or_Other_Blockage_Removed_2012_2017.shp") %>% sf::st_make_valid()
counties <- sf::read_sf("./CBW/County_Boundaries.shp") %>% sf::st_make_valid()
bmps <- read_csv("./CBW/BMPreport2016_landbmps.csv")
glimpse(bmps)
summary(bmps$Cost)
# min cost per state
bmps %>% group_by(StateAbbreviation) %>% summarise(costStat = mean(Cost, na.rm=T))
# mean cost per state
bmps %>% group_by(StateAbbreviation) %>% summarise(costStat = min(Cost, na.rm=T))
#median cost per state
bmps %>% group_by(StateAbbreviation) %>% summarise(costStat = median(Cost, na.rm=T))
#max cost per state
bmps %>% group_by(StateAbbreviation) %>% summarise(costStat = max(Cost, na.rm=T))
bmps %>% dplyr::filter(str_detect(Unit, "Acres")) %>%
ggplot(.,aes(x=TotalAmountCredited, y=Cost)) +
geom_point() + theme_classic() +
labs(x="Total Amount Credited", y="Cost")
bmps %>% dplyr::filter(str_detect(BMP, "Cover Crop")) %>%
ggplot(.,aes(x=StateAbbreviation, y=TotalAmountCredited)) +
geom_boxplot(aes(fill = StateAbbreviation)) + theme_classic() +
scale_y_log10() + labs(y="log10(total amount credited")
dams %>% dplyr::filter(., YEAR > 1) %>%
ggplot(.,aes(x=YEAR, y=STATE)) +
geom_point(color = "blue4") + theme_minimal()
#Grouping bmp cost and dam height by state name so I can join as a one to one
StateCost <- bmps %>% group_by(StateAbbreviation) %>% summarise(avgcost = mean(Cost, na.rm=T))
DamHeight <- dams %>% group_by(STATE) %>% summarise(avgheight = mean(HEIGHT, na.rm=T))
StateCost
DamHeight
#joining
dams.statecost <- left_join(DamHeight, StateCost, by= c("STATE"="StateAbbreviation"))
dams.statecost
#plotting to see any correlation between avg bmp cost and dam height within states
dams.statecost %>%
ggplot(., aes(x=avgheight, y=avgcost, color=STATE)) +
geom_point(size=3) + theme_minimal() +
labs(title = "Dam Height and Sediment Reduction Cost", subtitle = "In Maryland, Pennsylvania, and Virgina", x="Average dam height", y="Average managment cost")
glimpse(streams)
streams %>% dplyr::select(GNIS_Name, LengthKM) %>% dplyr::slice_max(LengthKM,n=5)
glimpse(dams)
glimpse(streams)
st_crs(dams)==st_crs(streams)
# making distance matrix
dists <- st_distance(streams, dams)
dim(dists)
dists[1:3,1:3]
# finding the smallest distance in each row
dams$dist <- apply(distances, 1, which.min)
# making distance matrix
distances <- st_distance(streams, dams)
dim(distances)
distances[1:3,1:3]
# finding the smallest distance in each row
dams$dist <- apply(distances, 1, which.min)
dams$dist
distances <- st_distance(dams, streams)
dim(distances)
distances[1:3,1:3]
# finding the smallest distance in each row
dams$dist <- apply(distances, 1, which.min)
dams$dist
dams %>% select(DAM_NAME, dist) %>% glimpse()
#finding the stream thats the smallest distance to each dam
close.stream <- dams$dist %>% streams[.,] %>% select(GNIS_Name)
close.stream
closest <- tibble(dam = dams$DAM_NAME, closest.stream = close.stream)
closest
dams %>% group_by(STATE) %>% count()
st_crs(counties)==st_crs(streams)
county.streams <- st_join(streams, counties)
#the three counties with the greatest total stream length
county.streams.length <- county.streams %>% group_by(COUNTYFP10) %>% summarise(TotalStreamLength = sum(LengthKM, na.rm=T)) %>% dplyr::slice_max(TotalStreamLength, n=3)
county.streams.length
glimpse(streams)
county.streams.length <- county.streams %>% group_by(COUNTYFP10) %>% summarise(TotalStreamLength = sum(Shape_Le_1, na.rm=T)) %>% dplyr::slice_max(TotalStreamLength, n=3)
county.streams.length
glimpse(streams)
#the three counties with the greatest total stream length
county.streams.length <- county.streams %>% group_by(COUNTYFP10) %>% summarise(TotalStreamLength = sum(LengthKM, na.rm=T)) %>% dplyr::slice_max(TotalStreamLength, n=3)
county.streams.length
library(tidyverse)
library(sf)
library(tmap)
streams <- sf::read_sf("./CBW/Streams_Opened_by_Dam_Removal_2012_2017.shp") %>% sf::st_make_valid()
dams <- sf::read_sf("./CBW/Dam_or_Other_Blockage_Removed_2012_2017.shp") %>% sf::st_make_valid()
counties <- sf::read_sf("./CBW/County_Boundaries.shp") %>% sf::st_make_valid()
bmps <- read_csv("./CBW/BMPreport2016_landbmps.csv")
glimpse(streams)
glimpse(dams)
glimpse(counties)
#make new column of just what comes before comma in Geography
bmps1 <- bmps %>% separate(col = Geography, into = c("county","where"), sep = ",")
bmps1$county
#join
county.bmp <- left_join(counties, bmps1, by = c("NAME10" = "county"))
glimpse(county.bmp)
county.cost <- county.bmp %>% group_by(NAME10)
glimpse(county.cost)
nrow(county.bmp)
nrow(county.cost)
#group by county
county.cost <- county.bmp %>% group_by(NAME10) %>% summarise(CountyCost = sum(Cost, na.rm=T))
county.bmp %>% select(NAME10, Cost)
county.bmp %>% select(NAME10, Shape_Leng, Shape_Area, geometry, Cost)
simple <- county.bmp %>% select(NAME10, Shape_Leng, Shape_Area, geometry, Cost)
glimpse(simple)
county.cost <- simple %>% group_by(NAME10) %>% summarise(CountyCost = sum(Cost, na.rm=T))
glimpse(county.bmp)
#map
county.bmp %>% group_by(NAME10) %>% summarise(CountyCost = sum(Cost, na.rm=T)) %>% tm_shape(.) + tm_polygons(fill="CountyCost")
glimpse(bmps1)
#what if i groups cost by county before the join
bmps2 <- bmps1 %>% group_by(county) %>% summarise(CountyCost = sum(Cost, na.rm=T))
glimpse(bmps2)
#join
county.bmp2 <- left_join(counties, bmps2, by = c("NAME10" = "county"))
glimpse(county.bmp)
counties %>% tm_shape() + tm_polygons()
county.bmp2 %>% tm_shape() + tm_polygons()
glimpse(county.bmp2)
county.bmp2 %>% tm_shape() + tm_polygons(fill = Cost)
county.bmp2 %>% tm_shape() + tm_polygons(fill = CountyCost)
county.bmp2$CountyCost
county.bmp2 %>% tm_shape() + tm_polygons(fill = "CountyCost")
