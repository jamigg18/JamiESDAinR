```{r}

#read data
ohio_counties <- sf::read_sf("./data/static_mapping/oh_counties.gpkg")
ohio_census   <- sf::read_sf("./data/static_mapping/oh_counties_DP2020.csv")

#Join
county_join <- left_join(ohio_counties, ohio_census,
                         join_by("GEOIDFQ" == "geoid"))

# proportion of demographic Variable 
county_census <- county_join %>%
  mutate(prop_amindianat = as.numeric(amindianat) / as.numeric(poptotal))

#drop NA
county_census <- county_census %>%
  filter(!is.na(prop_amindianat)) %>%
  st_make_valid()

#Spatial Weights Matrix
# Queen contiguity neighbors
nb <- poly2nb(county_census, queen = TRUE)
lw <- nb2listw(nb, style = "W", zero.policy = TRUE)

#Local Moran's I
lisa <- localmoran(county_census$prop_amindianat, lw, zero.policy = TRUE)
county_census$local_I  <- lisa[, "Ii"]
county_census$lisa_pval <- lisa[, "Pr(z != E(Ii))"]

#LISA Quadrant Labels
# Mean-center the variable and the spatial lag
x     <- county_census$prop_amindianat
x_lag <- lag.listw(lw, x, zero.policy = TRUE)

x_mean     <- mean(x,     na.rm = TRUE)
xlag_mean  <- mean(x_lag, na.rm = TRUE)

county_census <- county_census %>%
  mutate(
    quad = case_when(
      x >  x_mean & x_lag >  xlag_mean ~ "HH",
      x >  x_mean & x_lag <= xlag_mean ~ "HL",
      x <= x_mean & x_lag >  xlag_mean ~ "LH",
      x <= x_mean & x_lag <= xlag_mean ~ "LL"
    ),
    # Mark non-significant as NS (p > 0.05)
    quad_sig = ifelse(lisa_pval > 0.05, "NS", quad)
  )

#Color for LISA Quadrants
quad_levels  <- c("HH", "HL", "LH", "LL", "NS")
quad_colors  <- c(
  "HH" = "#d7191c",          
  "HL" = "#fdae61",   
  "LH" = "#abd9e9",   
  "LL" = "#2c7bb6",   
  "NS" = "#d3d3d3"    
)

county_census$quad_sig <- factor(county_census$quad_sig, levels = quad_levels)

#Popup
county_census <- county_census %>%
  mutate(
    popup_lisa = paste0(
      "<b>", NAME, " County</b><br>",
      "LISA Quadrant: <b>", quad_sig, "</b><br>",
      "Local Moran p-value: <b>", round(lisa_pval, 4), "</b>"
    )
  )

#Reproject for Leaflet
county_wgs <- st_transform(county_census, crs = 4326)

#Map
leaflet(county_wgs) %>%
  addProviderTiles(providers$Esri.NatGeoWorldMap) %>%
  addPolygons(
    fillColor   = ~quad_pal(quad_sig),
    fillOpacity = 0.8,
    color       = "white",
    weight      = 1,
    popup       = ~popup_lisa,
    highlightOptions = highlightOptions(
      weight       = 2,
      color        = "#333",
      fillOpacity  = 0.9,
      bringToFront = TRUE
    )
  ) %>%
  addLegend(
    position = "bottomright",
    title    = "LISA Quadrant",
    colors   = unname(quad_colors),
    labels   = c("HH – High-High (cluster)",
                 "HL – High-Low (outlier)",
                 "LH – Low-High (outlier)",
                 "LL – Low-Low (cluster)",
                 "NS – Not Significant"),
    opacity  = 0.9
  )


```

