# layers I'm using:
#  - [social layer]: population (normalized by area)
#  - [environmental layer]: land cover
#read in ohio data
ohio_counties <- sf::read_sf("./data/static_mapping/oh_counties.gpkg") %>% sf::st_transform(., 4326)
ohio_census <- sf::read_sf("./data/static_mapping/oh_counties_DP2020.csv")
#join the data
county_join <- left_join(ohio_counties, ohio_census, join_by("GEOIDFQ"  == "geoid"))
#make a column for the proportion of population count normalized by the are of land in the county
county_pop <- county_join %>% mutate(pop_per_area = as.numeric(poptotal) / (ALAND))
#subset data to the northeastern region of ohio
northeast_oh <- county_pop %>% dplyr::filter(NAME %in% c("Portage", "Summit", "Ashtabula", "Lake", "Geauga", "Trumbull", "Cuyahoga", "Mahoning", "Stark", "Lorain", "Medina", "Wayne", "Columbiana"))
#read in raster data to look at land cover, project it to be the same crs as the ohio data, and crop it to the northeastern ohio data, and decreasing resolution
land_cover <- terra::rast("./data/ohio/neoh_nlcd.tif") %>% terra::project(., sf::st_crs(county_pop)$wkt) %>% terra::crop(., northeast_oh) %>% terra::aggregate(., 5, fun = mean)
# defining breaks and palettes
min(northeast_oh$pop_per_area, na.rm = TRUE)
max(northeast_oh$pop_per_area, na.rm = TRUE)
breaks3 <- seq(min(5.363412e-05), max(0.001068102), length.out = 6)
pal <- colorBin(palette = "Purples", domain = northeast_oh$pop_per_area, bins = breaks3)
palLC <- colorNumeric(palette = "viridis",
domain = values(land_cover), na.color = "transparent")
#map
leaflet() %>%
setView(lng = -80.0, lat = 41.4, zoom = 7) %>%
addTiles() %>%
addPolygons(data = northeast_oh, group = "Population Map",
fillColor = ~pal(pop_per_area),
weight = 1, color = "black", fillOpacity = 0.8,
popup       = ~paste0("Population per unit of area: ", northeast_oh$pop_per_area)) %>%
addRasterImage(land_cover, group = "Land Cover Map",
colors = palLC, opacity = 0.8) %>%
addLayersControl(
overlayGroups = c("Population Map", "Land Cover Map"),
options = layersControlOptions(collapsed = FALSE))
# My "one thing": I added a popup showing the total population divided by area
