# Chunk 1: packages
library(sf)
library(leaflet)
library(tidyverse)
library(spdep)   # needed for Task 2 (Moran/LISA)
library(tidycensus) #for task 2
library(terra) #for task 3
# Chunk 2: task1_data
counties <- sf::read_sf("./data/CBW/County_Boundaries.shp") %>% sf::st_make_valid()
bmps <- read_csv("./data/CBW/BMPreport2016_landbmps.csv")
glimpse(counties)
glimpse(bmps)
bmps$Geography
counties$NAME10
#make new column of just what comes before comma in Geography
bmps1 <- bmps %>% separate(col = Geography, into = c("county","where"), sep = ",")
bmps1$county
#group cost by county before the join
bmps2 <- bmps1 %>% group_by(county) %>% summarise(CountyCost = sum(Cost, na.rm=T))
glimpse(bmps2)
#join
counties_bmp <- left_join(counties, bmps2, by = c("NAME10" = "county"))
glimpse(counties_bmp)
st_crs(counties_bmp)
# Chunk 3: task1_palette
# define breaks and palette here
min(counties_bmp$CountyCost, na.rm = TRUE)
max(counties_bmp$CountyCost, na.rm = TRUE)
breaks <- seq(min(181.2445), max(161575828), length.out = 6)
costcolors <- colorBin(palette = "PuRd", domain = counties_bmp$CountyCost, bins = breaks)
# Chunk 4: task1_map
leaflet(data = counties_bmp) %>%
setView(lng = -76.5, lat = 40.5, zoom = 5) %>%
addTiles() %>%
addPolygons(., fillColor = ~costcolors(CountyCost),
weight = 1, color = "black", fillOpacity = 0.8,
label = ~paste0(NAME10, ": ", CountyCost)) %>%
addLegend(position = "bottomright", pal = costcolors, values =  costcolors, title = "Cost of BMPs") %>%
addProviderTiles(providers$CartoDB.Voyager)
# Chunk 5: task2_data
sex.by.age <- get_acs(geography = "county", table = "B01001", output = "wide", geometry = T, year = 2020)
local.states <- sex.by.age %>% mutate(., STATEID = stringr::str_sub(GEOID,1,2)) %>% dplyr::filter(STATEID %in% c("39","42","24","54","51")) %>% sf::st_transform(., "ESRI:102010")
#maping proportion of 21 year old females to total female population
#normalizing
local.states2 <- local.states %>% mutate(., f21prop = B01001_033E/B01001_026E)
#Developing contiguity-based spatial weights matrix (queen)
#row-standardize the W
nbh <- spdep::poly2nb(local.states2, queen = TRUE)
w <- spdep::nb2listw(nbh, style = "W", zero.policy = TRUE)
#make Moran plot
moran.plot(local.states2$f21prop, w, zero.policy = TRUE, plot = TRUE)
lisa <- localmoran(local.states2$f21prop, w, zero.policy = TRUE)
counties_lisa <- sf::st_transform(local.states2, 4326)
counties_lisa$pval <- lisa[,5]
x <- counties_lisa$f21prop
wx <- lag.listw(w, x, zero.policy = TRUE)
xm <- mean(x)
wxm <- mean(wx)
counties_lisa$quadrant <- case_when(
x>xm & wx>wxm ~"HH",
x<xm & wx<wxm ~"LL",
x<xm & wx>wxm ~"LH",
x>xm & wx<wxm ~"HL",
)
glimpse(counties_lisa)
# Chunk 6: task2_palette
pal_lisa <- colorFactor(palette = c("red2","orange","lightgreen","blueviolet"), levels = c("HH", "HL", "LH", "LL"))
# Chunk 7: task2_map
leaflet(counties_lisa) %>%
addPolygons(
fillColor   = ~pal_lisa(quadrant),
fillOpacity = 0.8,
color       = "black",
weight      = 1,
popup = ~paste0(sprintf("%.3f", pval))) %>%
addLegend(position = "topright", pal = pal_lisa, values = counties_lisa$quadrant, title = "Moran's I Quadrant")  %>%
addProviderTiles(providers$Esri.NatGeoWorldMap,
group = "NatGeo World Map")  %>%
addProviderTiles(providers$Esri.WorldImagery,
group = "Satellite View") %>%
addProviderTiles(providers$CartoDB.Voyager,
group = "CartoDB Voyager") %>%
addLayersControl(
baseGroups = c("NatGeo World Map", "Satellite View", "CartoDB Voyager"))
# Chunk 8: task3_data
# layers I'm using:
#  - [social layer]: population (normalized by area)
#  - [environmental layer]: land cover
#read in ohio data
ohio_counties <- sf::read_sf("./data/static_mapping/oh_counties.gpkg") %>% sf::st_transform(., 4326)
ohio_census <- sf::read_sf("./data/static_mapping/oh_counties_DP2020.csv")
#join the data
county_join <- left_join(ohio_counties, ohio_census, join_by("GEOIDFQ"  == "geoid"))
#make a column for the proportion of population count normalized by the are of land in the county
county_pop <- county_join %>% mutate(pop_per_area = as.numeric(poptotal) / (ALAND))
#subset data to the northeastern region of ohio
northeast_oh <- county_pop %>% dplyr::filter(NAME %in% c("Portage", "Summit", "Ashtabula", "Lake", "Geauga", "Trumbull", "Cuyahoga", "Mahoning", "Stark", "Lorain", "Medina", "Wayne", "Columbiana"))
#read in raster data to look at land cover, project it to be the same crs as the ohio data, and crop it to the northeastern ohio data, and decreasing resolution
land_cover <- terra::rast("./data/ohio/neoh_nlcd.tif") %>% terra::project(., sf::st_crs(county_pop)$wkt) %>% terra::crop(., northeast_oh) %>% terra::aggregate(., 5, fun = mean)
